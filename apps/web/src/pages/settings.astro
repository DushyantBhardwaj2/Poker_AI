---
import MainLayout from '../layouts/MainLayout.astro';
import { Info } from 'lucide-react';
---

<MainLayout title="Settings - PokerSense AI">
  <div class="glass-dark p-12 rounded-[40px] border border-white/5 text-center space-y-6 w-full max-w-2xl">
    <div class="flex justify-center">
      <Info className="text-gold" size={48} />
    </div>
    <h2 class="text-3xl font-black text-white uppercase tracking-widest">Settings</h2>
    <p class="text-cream/40">Configuration options for AI engine and UI preferences coming soon.</p>
  </div>
</MainLayout>
